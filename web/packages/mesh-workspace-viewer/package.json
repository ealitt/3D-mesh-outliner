{
  "name": "@mesh2cad/mesh-workspace-viewer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "peerDependencies": {
    "preact": "^10.29.0",
    "three": "^0.181.1"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && vite build && cp src/styles/base.css dist/styles.css && cp src/styles/tokens.css dist/tokens.css",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  }
}
