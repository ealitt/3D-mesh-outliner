{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["ES2023", "DOM", "DOM.Iterable", "WebWorker"],
    "allowJs": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@mesh2cad/mesh-workspace-viewer": ["./packages/mesh-workspace-viewer/src/index.ts"],
      "@mesh2cad/mesh-workspace-viewer/styles.css": ["./packages/mesh-workspace-viewer/src/styles/base.css"]
    },
    "jsx": "react-jsx",
    "jsxImportSource": "preact",
    "types": ["vite/client", "vite-plugin-pwa/preact"]
  },
  "include": ["src"]
}
